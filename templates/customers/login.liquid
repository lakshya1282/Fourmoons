<div class="login-page" style="padding: 150px 40px; text-align: center; max-width: 500px; margin: 0 auto;">
  <h1 style="font-family: serif; font-size: 42px; margin-bottom: 40px;">Login</h1>

  {% form 'customer_login' %}
    {{ form.errors | default_errors }}

    <div style="margin-bottom: 20px;">
      <input type="email" name="customer[email]" placeholder="Email" style="width: 100%; padding: 15px; border: 1px solid #ddd;">
    </div>

    <div style="margin-bottom: 30px;">
      <input type="password" name="customer[password]" placeholder="Password" style="width: 100%; padding: 15px; border: 1px solid #ddd;">
    </div>

    <button type="submit" style="width: 100%; padding: 15px; background: #000; color: #fff; border: none; cursor: pointer; text-transform: uppercase; letter-spacing: 0.1em; font-weight: 600;">Sign In</button>

    <div style="margin-top: 20px;">
      <a href="{{ routes.account_register_url }}" style="font-size: 14px; color: #888;">Create account</a>
    </div>
  {% endform %}
</div>
