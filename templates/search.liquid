<div class="search-page" style="padding: 120px 40px; max-width: 1200px; margin: 0 auto;">
  <h1 style="font-family: serif; font-size: 42px; margin-bottom: 40px;">Search Results</h1>

  <form action="{{ routes.search_url }}" method="get" role="search" style="margin-bottom: 60px;">
    <input type="search" name="q" value="{{ search.terms | escape }}" placeholder="Search our store..." style="width: 100%; max-width: 600px; padding: 20px; border: 1px solid #ddd; font-size: 16px;">
    <button type="submit" style="padding: 20px 40px; background: #000; color: #fff; border: none; cursor: pointer; text-transform: uppercase; letter-spacing: 0.1em; font-weight: 600;">Search</button>
  </form>

  {% if search.performed %}
    <div class="search-results-grid" style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 30px;">
      {% for item in search.results %}
        <div class="search-item">
          {% if item.featured_image %}
            <a href="{{ item.url }}" style="display: block; margin-bottom: 15px;">
              <img src="{{ item.featured_image | image_url: width: 400 }}" alt="{{ item.title }}" style="width: 100%;">
            </a>
          {% endif %}
          <h3 style="font-size: 14px; margin: 0;"><a href="{{ item.url }}" style="color: inherit; text-decoration: none;">{{ item.title }}</a></h3>
          <p style="font-weight: 600; margin-top: 5px;">{{ item.price | money }}</p>
        </div>
      {% endfor %}
    </div>

    {% if search.results_count == 0 %}
      <p>No results found for "{{ search.terms }}".</p>
    {% endif %}
  {% endif %}
</div>
