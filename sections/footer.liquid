<style>
  .site-footer {
    padding: 100px 40px 40px;
    background-color: #fff;
    border-top: 1px solid #f0f0f0;
    color: #333;
  }
  .footer-container {
    max-width: 1400px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr 1fr;
    gap: 60px;
    margin-bottom: 80px;
  }
  .footer-logo {
    display: block;
    margin-bottom: 25px;
    text-decoration: none;
  }
  .footer-logo img {
    height: 50px;
    width: auto;
    object-fit: contain;
    filter: brightness(0);
  }
  .footer-description {
    font-size: 14px;
    line-height: 1.8;
    color: #666;
    max-width: 300px;
    margin: 0;
  }
  .footer-heading {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    font-weight: 700;
    margin-bottom: 30px;
    color: #000;
  }
  .footer-links {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .footer-link-item {
    margin-bottom: 12px;
  }
  .footer-link {
    font-size: 13px;
    color: #666;
    text-decoration: none;
    transition: color 0.3s ease;
  }
  .footer-link:hover {
    color: #000;
  }
  .footer-socials {
    display: flex;
    gap: 20px;
  }
  .social-icon {
    color: #333;
    transition: color 0.3s ease;
  }
  .social-icon:hover {
    color: #000;
  }
  .footer-bottom {
    max-width: 1400px;
    margin: 0 auto;
    padding-top: 40px;
    border-top: 1px solid #f5f5f5;
    text-align: center;
  }
  .copyright-text {
    font-size: 11px;
    color: #999;
    letter-spacing: 0.05em;
  }

  @media (max-width: 1024px) {
    .footer-container {
      grid-template-columns: 1fr 1fr;
    }
    .footer-brand {
      grid-column: span 2;
      margin-bottom: 40px;
    }
  }
  @media (max-width: 600px) {
    .footer-container {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    .footer-brand {
      grid-column: span 1;
    }
  }
</style>

<footer class="site-footer">
