<style>
  .newsletter-section {
    padding: 60px 40px;
    background-color: #fcfcfc;
    border-top: 1px solid #eee;
    border-bottom: 1px solid #eee;
  }
  .newsletter-container {
    max-width: 1400px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 40px;
  }
  .newsletter-content {
    display: flex;
    align-items: center;
    gap: 30px;
  }
  .newsletter-icon {
    width: 60px;
    height: 60px;
    color: #333;
    flex-shrink: 0;
  }
  .newsletter-text {
    text-align: left;
  }
  .newsletter-title {
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    font-weight: 700;
    margin: 0 0 5px 0;
    color: #000;
  }
  .newsletter-description {
    font-size: 14px;
    color: #666;
    margin: 0;
  }
  .newsletter-form {
    display: flex;
    gap: 0;
    width: 100%;
    max-width: 500px;
  }
  .newsletter-input {
    flex: 1;
    padding: 18px 25px;
    border: 1px solid #ddd;
    font-size: 14px;
    outline: none;
    background: #fff;
  }
  .newsletter-submit {
    background-color: #000;
    color: #fff;
    border: 1px solid #000;
    padding: 0 40px;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    font-weight: 700;
    cursor: pointer;
    transition: background 0.3s ease;
  }
  .newsletter-submit:hover {
    background-color: #333;
  }

  @media (max-width: 1024px) {
    .newsletter-container {
      flex-direction: column;
      text-align: center;
    }
    .newsletter-content {
      flex-direction: column;
      text-align: center;
    }
    .newsletter-form {
      max-width: 100%;
    }
  }
</style>

<section class="newsletter-section">
  <div class="newsletter-container" data-aos="fade-up">
    <div class="newsletter-content">
      <div class="newsletter-icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="60" height="60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2"/><path d="M3 10h18"/><path d="M8 4v18"/><path d="M16 4v18"/><path d="m7 15 5 5 5-5"/></svg>
      </div>
      <div class="newsletter-text">
        <h2 class="newsletter-title">Join the Luxora Community</h2>
        <p class="newsletter-description">Get 10% off your first order and early access to new launches.</p>
      </div>
    </div>

    <form method="post" action="/contact#contact_form" class="newsletter-form">
      <input type="hidden" name="form_type" value="customer">
      <input type="email" name="contact[email]" class="newsletter-input" placeholder="Enter your email" required>
      <button type="submit" class="newsletter-submit">Subscribe</button>
    </form>
  </div>
</section>

{% schema %}
{
  "name": "Newsletter Bar",
  "settings": [],
  "presets": [
    {
      "name": "Newsletter Bar"
    }
  ]
}
{% endschema %}
