<style>
  .footer-promos {
    background-color: #fdfaf5;
    padding: 60px 40px;
  }

  /* Values Bar */
  .values-bar {
    max-width: 1400px;
    margin: 0 auto 60px auto;
    display: flex;
    justify-content: space-between;
    padding: 40px;
    border: 1px solid #efebe5;
    background: #fff;
    border-radius: 4px;
    flex-wrap: wrap;
  }

  .value-item {
    flex: 1;
    display: flex;
    gap: 20px;
    padding: 0 30px;
    border-right: 1px solid #efebe5;
    min-width: 250px;
    margin-bottom: 20px;
  }

  .value-item:last-child {
    border-right: none;
  }

  .value-icon {
    width: 40px;
    height: 40px;
    flex-shrink: 0;
    color: #c5a880;
  }

  .value-icon svg {
    width: 100%;
    height: 100%;
  }

  .value-content h3 {
    font-size: 11px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin: 0 0 8px 0;
    color: #1a1a1a;
  }

  .value-content p {
    font-size: 11px;
    line-height: 1.6;
    color: #666;
    margin: 0;
  }

  /* Newsletter Section */
  .newsletter-promo {
    max-width: 1400px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    background: #f4f1eb;
    border-radius: 4px;
    overflow: hidden;
  }

  .newsletter-content {
    flex: 1;
    padding: 60px 80px;
  }

  .newsletter-content h2 {
    font-family: 'Lora', serif;
    font-size: 36px;
    font-weight: 400;
    margin: 0 0 15px 0;
    color: #1a1a1a;
  }

  .newsletter-content p {
    font-size: 14px;
    line-height: 1.6;
    color: #666;
    margin-bottom: 30px;
    max-width: 400px;
  }

  .newsletter-form {
    display: flex;
    max-width: 500px;
  }

  .newsletter-input {
    flex: 1;
    padding: 15px 25px;
    border: 1px solid #dcdcdc;
    border-right: none;
    font-size: 13px;
    background: #fff;
    outline: none;
  }

  .newsletter-submit {
    background: #1a1a1a;
    color: #fff;
    border: none;
    padding: 0 35px;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    cursor: pointer;
    transition: background 0.3s ease;
  }

  .newsletter-submit:hover {
    background: #333;
  }

  .newsletter-image {
    width: 40%;
    height: 350px;
  }

  .newsletter-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media (max-width: 1024px) {
    .value-item {
      flex: 1 1 40%;
      border-right: none;
    }
    .newsletter-promo {
      flex-direction: column;
    }
    .newsletter-image {
      width: 100%;
      height: 300px;
    }
    .newsletter-content {
      padding: 40px;
    }
  }

  @media (max-width: 768px) {
    .value-item {
      flex: 1 1 100%;
      padding: 0;
    }
    .footer-promos {
      padding: 40px 20px;
    }
    .values-bar {
      padding: 30px 20px;
    }
  }
</style>

<section class="footer-promos">
  <!-- Values Bar -->
  {% if section.blocks.size > 0 %}
    <div class="values-bar">
      {% for block in section.blocks %}
        <div class="value-item" {{ block.shopify_attributes }}>
          <div class="value-icon">
            {% if block.settings.icon_svg != blank %}
              {{ block.settings.icon_svg }}
            {% else %}
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a10 10 0 0 1 10 10c0 5.523-4.477 10-10 10S2 17.523 2 12 6.477 2 12 2Z"></path><path d="M12 22V12"></path><path d="M12 12 2.2 7.6"></path><path d="M12 12l9.8-4.4"></path></svg>
            {% endif %}
          </div>
          <div class="value-content">
            <h3>{{ block.settings.title }}</h3>
            <p>{{ block.settings.text }}</p>
          </div>
        </div>
      {% endfor %}
    </div>
  {% endif %}

  <!-- Newsletter -->
  <div class="newsletter-promo">
    <div class="newsletter-content">
      <h2>{{ section.settings.newsletter_title }}</h2>
      <p>{{ section.settings.newsletter_text }}</p>
      
      {% if section.settings.newsletter_app == 'shopify' %}
        {% form 'customer', class: 'newsletter-form' %}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <input type="email" 
            name="contact[email]" 
            class="newsletter-input" 
            placeholder="{{ 'newsletter.label' | t | default: 'Your email address' }}" 
            required>
          <button type="submit" class="newsletter-submit">
            {{ 'newsletter.button_label' | t | default: 'Subscribe' }}
          </button>
          
          {% if form.posted_successfully? %}
            <p class="newsletter-success" style="margin-top: 15px; color: #4CAF50; font-size: 13px;">
              {{ 'newsletter.success' | t | default: 'Thanks for subscribing!' }}
            </p>
          {% endif %}
        {% endform %}
      {% else %}
        <div class="custom-newsletter-embed">
          {{ section.settings.newsletter_embed }}
        </div>
      {% endif %}
    </div>
    <div class="newsletter-image">
      {% if section.settings.newsletter_image != blank %}
        <img src="{{ section.settings.newsletter_image | image_url: width: 800 }}" alt="{{ section.settings.newsletter_title }}">
      {% else %}
        <img src="{{ 'products-hero-1.png' | asset_url }}" alt="Newsletter image">
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Footer Promos",
  "settings": [
    {
      "type": "header",
      "content": "Newsletter Settings"
    },
    {
      "type": "text",
      "id": "newsletter_title",
      "label": "Newsletter Title",
      "default": "Stay in the loop"
    },
    {
      "type": "textarea",
      "id": "newsletter_text",
      "label": "Newsletter Subtitle",
      "default": "Be the first to know about new scents, exclusive offers, and more."
    },
    {
      "type": "image_picker",
      "id": "newsletter_image",
      "label": "Newsletter Image"
    },
    {
      "type": "select",
      "id": "newsletter_app",
      "label": "Newsletter App",
      "options": [
        { "value": "shopify", "label": "Shopify (Default)" },
        { "value": "custom", "label": "Klaviyo / Other App (Manual Embed)" }
      ],
      "default": "shopify"
    },
    {
      "type": "html",
      "id": "newsletter_embed",
      "label": "Custom Form Embed Code",
      "info": "If using Klaviyo or another app, paste your form embed code here."
    }
  ],
  "blocks": [
    {
      "type": "value_item",
      "name": "Value Item",
      "limit": 4,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Value Title"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description",
          "default": "Add a short description of your brand value."
        },
        {
          "type": "html",
          "id": "icon_svg",
          "label": "SVG Icon Code",
          "info": "Paste SVG code from icons (like Lucide or Feather Icons)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Footer Promos",
      "blocks": [
        {
          "type": "value_item",
          "settings": {
            "title": "Natural Ingredients",
            "text": "Made with clean, non-toxic fragrances and natural waxes."
          }
        },
        {
          "type": "value_item",
          "settings": {
            "title": "Hand Poured",
            "text": "Thoughtfully crafted in small batches with care."
          }
        },
        {
          "type": "value_item",
          "settings": {
            "title": "Made to Last",
            "text": "Slow burning, long lasting scents you'll love."
          }
        },
        {
          "type": "value_item",
          "settings": {
            "title": "Sustainable",
            "text": "Eco-friendly packaging and responsible sourcing."
          }
        }
      ]
    }
  ]
}
{% endschema %}
