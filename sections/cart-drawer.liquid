<style>
  .cart-drawer-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.4);
    backdrop-filter: blur(4px);
    z-index: 1000;
    opacity: 0;
    visibility: hidden;
    transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
  }

  .cart-drawer-overlay.active {
    opacity: 1;
    visibility: visible;
  }

  .cart-drawer {
    position: fixed;
    top: 0;
    right: -450px;
    width: 100%;
    max-width: 450px;
    height: 100%;
    background: #fff;
    z-index: 1001;
    transition: all 0.5s cubic-bezier(0.165, 0.84, 0.44, 1);
    display: flex;
    flex-direction: column;
    box-shadow: -10px 0 30px rgba(0, 0, 0, 0.1);
  }

  .cart-drawer.active {
    right: 0;
  }

  .cart-drawer-header {
    padding: 30px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-bottom: 1px solid #f0f0f0;
  }

  .cart-drawer-header h2 {
    margin: 0;
    font-family: var(--font-heading-family);
    font-size: 24px;
    font-weight: 500;
  }

  .cart-drawer-close {
    background: none;
    border: none;
    cursor: pointer;
    padding: 5px;
    color: #000;
    opacity: 0.6;
    transition: opacity 0.3s ease;
  }

  .cart-drawer-close:hover {
    opacity: 1;
  }

  .cart-drawer-items {
    flex: 1;
    overflow-y: auto;
    padding: 30px;
  }

  .cart-drawer-item {
    display: flex;
    gap: 20px;
    margin-bottom: 25px;
    padding-bottom: 25px;
    border-bottom: 1px solid #f9f9f9;
  }

  .cart-drawer-item-image {
    width: 90px;
    height: 120px;
    background: #f5f5f5;
    flex-shrink: 0;
  }

  .cart-drawer-item-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .cart-drawer-item-info {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .cart-drawer-item-title {
    font-size: 14px;
    font-weight: 500;
    margin: 0 0 5px 0;
    color: #000;
    text-decoration: none;
  }

  .cart-drawer-item-variant {
    font-size: 12px;
    color: #888;
    margin-bottom: 10px;
  }

  .cart-drawer-item-price {
    font-size: 14px;
    font-weight: 600;
    margin-bottom: 15px;
  }

  .cart-drawer-quantity-selector {
    display: flex;
    align-items: center;
    border: 1px solid #e0e0e0;
    width: fit-content;
    border-radius: 4px;
  }

  .cart-drawer-quantity-btn {
    background: none;
    border: none;
    width: 30px;
    height: 30px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 16px;
  }

  .cart-drawer-quantity-input {
    width: 30px;
    text-align: center;
    border: none;
    font-size: 13px;
    font-weight: 500;
    -moz-appearance: textfield;
  }

  .cart-drawer-quantity-input::-webkit-outer-spin-button,
  .cart-drawer-quantity-input::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }

  .cart-drawer-item-remove {
    font-size: 11px;
    color: #888;
    text-decoration: underline;
    cursor: pointer;
    background: none;
    border: none;
    padding: 0;
    margin-top: 10px;
    text-align: left;
  }

  .cart-drawer-footer {
    padding: 30px;
    background: #fff;
    border-top: 1px solid #f0f0f0;
  }

  .cart-drawer-total {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 10px;
    font-size: 18px;
    font-weight: 600;
  }

  .cart-drawer-note {
    font-size: 12px;
    color: #888;
    margin-bottom: 25px;
  }

  .cart-drawer-checkout-btn {
    display: block;
    width: 100%;
    padding: 18px;
    background: #000;
    color: #fff;
    text-align: center;
    text-decoration: none;
    text-transform: uppercase;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.1em;
    transition: background 0.3s ease;
  }

  .cart-drawer-checkout-btn:hover {
    background: #222;
  }

  .cart-drawer-empty {
    text-align: center;
    padding-top: 100px;
  }

  .cart-drawer-empty p {
    color: #888;
    margin-bottom: 20px;
  }

  .cart-drawer-loading {
    display: flex;
    justify-content: center;
    padding-top: 50px;
    font-size: 14px;
    color: #888;
  }

  @media (max-width: 480px) {
    .cart-drawer {
      max-width: 100%;
      right: -100%;
    }
  }
</style>

<div id="cart-drawer-overlay" class="cart-drawer-overlay"></div>
<div id="cart-drawer" class="cart-drawer">
  <div class="cart-drawer-header">
    <h2>Your Cart</h2>
    <button id="cart-drawer-close" class="cart-drawer-close" aria-label="Close cart">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
    </button>
  </div>

  <div id="cart-drawer-items" class="cart-drawer-items">
    <div class="cart-drawer-loading">Loading your cart...</div>
  </div>

  <div class="cart-drawer-footer">
    <div class="cart-drawer-total">
      <span>Subtotal</span>
      <span id="cart-drawer-subtotal">{{ cart.total_price | money }}</span>
    </div>
    <p class="cart-drawer-note">Taxes and shipping calculated at checkout</p>
    <a href="/checkout" class="cart-drawer-checkout-btn">Check Out</a>
  </div>
</div>

<script>
  class CartDrawer {
    constructor() {
      this.moneyFormat = "{{ shop.money_format }}";
      this.drawer = document.getElementById('cart-drawer');
      this.overlay = document.getElementById('cart-drawer-overlay');
      this.closeBtn = document.getElementById('cart-drawer-close');
      this.itemsContainer = document.getElementById('cart-drawer-items');
      this.subtotalElement = document.getElementById('cart-drawer-subtotal');
      this.triggers = document.querySelectorAll('a[href="/cart"], .cart-drawer-trigger');

      this.init();
    }

    init() {
      this.triggers.forEach(trigger => {
        trigger.addEventListener('click', (e) => {
          e.preventDefault();
          this.open();
        });
      });

      this.closeBtn.addEventListener('click', () => this.close());
      this.overlay.addEventListener('click', () => this.close());
      this.refresh();
      document.addEventListener('cart:updated', () => this.refresh());
      document.addEventListener('submit', (e) => {
        if (e.target.action && e.target.action.includes('/cart/add')) {
          if (e.submitter && e.submitter.name === 'checkout') {
            return;
          }

          e.preventDefault();
          e.stopPropagation();
          this.addToCart(e.target);
        }
      }, true);
    }

    async addToCart(form) {
      const formData = new FormData(form);
      try {
        const response = await fetch('/cart/add.js', {
          method: 'POST',
          body: formData
        });
        const item = await response.json();
        this.open();
      } catch (error) {
        console.error('Error adding to cart:', error);
      }
    }

    open() {
      this.drawer.classList.add('active');
      this.overlay.classList.add('active');
      document.body.style.overflow = 'hidden';
      this.refresh();
    }

    close() {
      this.drawer.classList.remove('active');
      this.overlay.classList.remove('active');
      document.body.style.overflow = '';
    }

    async refresh() {
      try {
        const response = await fetch('/cart.js');
        const cart = await response.json();
        this.render(cart);
        this.updateHeaderCount(cart.item_count);
      } catch (error) {
        console.error('Error fetching cart:', error);
      }
    }

    render(cart) {
      if (cart.item_count === 0) {
        this.itemsContainer.innerHTML = `
          <div class="cart-drawer-empty">
            <p>Your cart is empty</p>
            <a href="{{ routes.all_products_collection_url }}" class="cart-drawer-checkout-btn" style="background: transparent; border: 1px solid #000; color: #000;">Shop Now</a>
          </div>
        `;
        this.subtotalElement.textContent = Shopify.formatMoney(0, this.moneyFormat);
        return;
      }

      let html = '';
      cart.items.forEach((item, index) => {
        html += `
          <div class="cart-drawer-item" data-line="${index + 1}">
            <div class="cart-drawer-item-image">
              <img src="${item.image}" alt="${item.title}">
            </div>
            <div class="cart-drawer-item-info">
              <div>
                <a href="${item.url}" class="cart-drawer-item-title">${item.product_title}</a>
                <div class="cart-drawer-item-variant">${item.variant_title || ''}</div>
                <div class="cart-drawer-item-price">${Shopify.formatMoney(item.price, this.moneyFormat)}</div>
              </div>
              <div>
                <div class="cart-drawer-quantity-selector">
                  <button class="cart-drawer-quantity-btn minus" data-id="${item.key}" data-qty="${item.quantity - 1}">-</button>
                  <input type="number" class="cart-drawer-quantity-input" value="${item.quantity}" readonly>
                  <button class="cart-drawer-quantity-btn plus" data-id="${item.key}" data-qty="${item.quantity + 1}">+</button>
                </div>
                <button class="cart-drawer-item-remove" data-id="${item.key}">Remove</button>
              </div>
            </div>
          </div>
        `;
      });

      this.itemsContainer.innerHTML = html;
      this.subtotalElement.textContent = Shopify.formatMoney(cart.total_price, this.moneyFormat);
      this.itemsContainer.querySelectorAll('.cart-drawer-quantity-btn').forEach(btn => {
        btn.addEventListener('click', (e) => {
          const id = e.currentTarget.dataset.id;
          const qty = e.currentTarget.dataset.qty;
          this.updateQuantity(id, qty);
        });
      });

      this.itemsContainer.querySelectorAll('.cart-drawer-item-remove').forEach(btn => {
        btn.addEventListener('click', (e) => {
          const id = e.currentTarget.dataset.id;
          this.updateQuantity(id, 0);
        });
      });
    }

    async updateQuantity(id, qty) {
      try {
        const response = await fetch('/cart/change.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id: id, quantity: parseInt(qty) })
        });
        const cart = await response.json();
        this.render(cart);
        this.updateHeaderCount(cart.item_count);
      } catch (error) {
        console.error('Error updating quantity:', error);
      }
    }

    updateHeaderCount(count) {
      const countElement = document.querySelector('.cart-count');
      if (countElement) {
        countElement.textContent = count;
        if (count > 0) {
          countElement.style.display = 'flex';
        } else {
          countElement.style.display = 'none';
        }
      }
    }
  }
  if (typeof Shopify === 'undefined') {
    var Shopify = {};
  }
  if (!Shopify.formatMoney) {
    Shopify.formatMoney = function(cents, format) {
      if (typeof cents == 'string') { cents = cents.replace('.',''); }
      var value = '';
      var placeholderRegex = /\{\{\s*(\w+)\s*\}\}/;
      var formatString = (format || "{{amount}}");

      function defaultOption(opt, def) {
        return (typeof opt == 'undefined' ? def : opt);
      }

      function formatWithDelimiters(number, precision, thousands, decimal) {
        precision = defaultOption(precision, 2);
        thousands = defaultOption(thousands, ',');
        decimal   = defaultOption(decimal, '.');

        if (isNaN(number) || number == null) { return 0; }

        number = (number/100.0).toFixed(precision);

        var parts   = number.split('.'),
            dollars = parts[0].replace(/(\d)(?=(\d\d\d)+(?!\d))/g, '$1' + thousands),
            cents   = parts[1] ? (decimal + parts[1]) : '';

        return dollars + cents;
      }

      switch(formatString.match(placeholderRegex)[1]) {
        case 'amount':
          value = formatWithDelimiters(cents, 2);
          break;
        case 'amount_no_decimals':
          value = formatWithDelimiters(cents, 0);
          break;
        case 'amount_with_comma_separator':
          value = formatWithDelimiters(cents, 2, '.', ',');
          break;
        case 'amount_no_decimals_with_comma_separator':
          value = formatWithDelimiters(cents, 0, '.', ',');
          break;
      }

      return formatString.replace(placeholderRegex, value);
    };
  }
  document.addEventListener('DOMContentLoaded', () => {
    window.cartDrawer = new CartDrawer();
  });
</script>

{% schema %}
{
  "name": "Cart Drawer",
  "settings": []
}
{% endschema %}
