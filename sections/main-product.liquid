<style>
  :root {
    --color-purple: #000000;
    --color-beige: #F8F6F2;
    --color-text-dark: #1A1A1A;
    --color-text-light: #666666;
    --color-border: #EEEEEE;
  }

  .product-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 60px 40px;
    font-family: 'Inter', sans-serif;
  }


  .breadcrumbs {
    font-size: 13px;
    color: var(--color-text-light);
    margin-bottom: 40px;
  }
  .breadcrumbs a { color: inherit; text-decoration: none; }
  .breadcrumbs span { margin: 0 10px; }


  .product-hero {
    display: grid;
    grid-template-columns: 80px 1fr 1fr;
    gap: 40px;
    align-items: start;
    margin-bottom: 100px;
  }


  .product-thumbnails {
    display: flex;
    flex-direction: column;
    gap: 15px;
  }
  .thumb-item {
    width: 80px;
    height: 80px;
    border-radius: 8px;
    overflow: hidden;
    cursor: pointer;
    border: 1px solid transparent;
    transition: border-color 0.3s;
  }
  .thumb-item.active { border-color: var(--color-purple); }
  .thumb-item img { width: 100%; height: 100%; object-fit: cover; }

  .product-main-media {
    position: relative;
    border-radius: 12px;
    overflow: hidden;
    background: #f9f9f9;
  }
  .product-main-media img { width: 100%; height: auto; display: block; }
  .zoom-icon {
    position: absolute;
    top: 20px;
    right: 20px;
    background: #fff;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 10px rgba(0,0,0,0.1);
  }


  .product-info-wrap {
    padding-left: 20px;
  }
  .best-seller-tag {
    display: inline-block;
    padding: 4px 12px;
    background: #f0f0f0;
    color: var(--color-purple);
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    border-radius: 100px;
    margin-bottom: 15px;
  }
  .product-title {
    font-family: 'Lora', serif;
    font-size: 42px;
    color: var(--color-text-dark);
    margin: 0 0 15px;
    font-weight: 400;
    line-height: 1.2;
  }
  .product-rating {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 25px;
    font-size: 14px;
    color: var(--color-text-light);
  }
  .stars { color: #FFB800; font-size: 18px; }

  .product-price {
    font-size: 28px;
    font-weight: 600;
    color: var(--color-text-dark);
    margin-bottom: 5px;
  }
  .tax-note { font-size: 13px; color: var(--color-text-light); margin-bottom: 30px; }

  .catch-phrase { font-weight: 700; color: var(--color-text-dark); margin-bottom: 10px; display: block; }
  .short-desc { font-size: 15px; color: var(--color-text-light); line-height: 1.6; margin-bottom: 35px; }


  .option-label { font-size: 13px; font-weight: 700; margin-bottom: 12px; display: block; }
  .size-pills { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; margin-bottom: 30px; }
  .size-pill {
    padding: 15px 10px;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    font-size: 13px;
    cursor: pointer;
    transition: all 0.3s;
    text-align: center;
    display: flex;
    flex-direction: column;
    justify-content: center;
    position: relative;
    background: #fff;
  }
  .size-pill.active { border-color: var(--color-purple); background: #fdfaf5; box-shadow: 0 0 0 1px var(--color-purple); }
  .size-pill:hover { border-color: #ccc; }

  .pill-name { font-weight: 700; margin-bottom: 4px; display: block; }
  .pill-info { font-size: 11px; color: var(--color-text-light); display: block; }
  .pill-price { font-size: 12px; font-weight: 700; margin-top: 6px; display: block; color: var(--color-text-dark); }

  .pill-popular {
    position: absolute;
    top: -10px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--color-purple);
    color: #fff;
    font-size: 8px;
    font-weight: 800;
    padding: 2px 8px;
    border-radius: 100px;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .qty-selector { display: flex; align-items: center; gap: 15px; margin-bottom: 40px; border-top: 1px solid var(--color-border); padding-top: 30px; }
  .qty-controls {
    display: flex;
    align-items: center;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    overflow: hidden;
  }
  .qty-btn {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: none;
    cursor: pointer;
    font-size: 18px;
  }
  .qty-input { width: 40px; text-align: center; border: none; font-size: 14px; outline: none; }

  .button-group { display: flex; gap: 15px; margin-bottom: 40px; }
  .btn-add-to-cart {
    flex: 2;
    background: var(--color-purple);
    color: #fff;
    border: none;
    padding: 20px;
    border-radius: 8px;
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    transition: all 0.3s ease;
  }
  .btn-add-to-cart:hover { background: #333; transform: translateY(-2px); }

  .btn-buy-now {
    flex: 1;
    background: transparent;
    color: var(--color-text-dark);
    border: 1px solid var(--color-text-dark);
    padding: 20px;
    border-radius: 8px;
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    cursor: pointer;
    transition: all 0.3s ease;
  }
  .btn-buy-now:hover { background: #f9f9f9; transform: translateY(-2px); }


  .trust-badges {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 15px;
    padding-top: 20px;
    border-top: 1px solid var(--color-border);
  }
  .trust-item { text-align: center; font-size: 11px; color: var(--color-text-light); line-height: 1.3; }
  .trust-item svg { width: 24px; height: 24px; margin-bottom: 8px; color: var(--color-purple); }


  .scent-notes-section {
    background: var(--color-beige);
    border-radius: 20px;
    padding: 60px 80px;
    margin-bottom: 100px;
    display: grid;
    grid-template-columns: 1.2fr 2fr;
    gap: 80px;
    align-items: center;
  }
  .notes-intro h2 { font-family: 'Lora', serif; font-size: 32px; margin-bottom: 20px; font-weight: 400; }
  .notes-intro p { font-size: 15px; color: var(--color-text-light); line-height: 1.8; }
  .notes-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
  .note-card { background: #fff; padding: 30px 20px; border-radius: 12px; text-align: center; }
  .note-card svg { width: 32px; height: 32px; margin-bottom: 15px; color: var(--color-purple); }
  .note-type { font-size: 11px; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-text-light); margin-bottom: 10px; display: block; }
  .note-name { font-size: 14px; font-weight: 700; color: var(--color-text-dark); line-height: 1.4; }


  .benefits-section { margin-bottom: 120px; text-align: center; }
  .benefits-section h2 { font-family: 'Lora', serif; font-size: 32px; margin-bottom: 50px; font-weight: 400; }
  .benefits-grid { display: grid; grid-template-columns: repeat(6, 1fr); gap: 20px; }
  .benefit-card { background: #F9F9F9; padding: 30px 15px; border-radius: 12px; display: flex; flex-direction: column; align-items: center; }
  .benefit-card svg { width: 30px; height: 30px; margin-bottom: 15px; color: var(--color-purple); }
  .benefit-title { font-size: 13px; font-weight: 700; margin-bottom: 8px; }
  .benefit-desc { font-size: 11px; color: var(--color-text-light); line-height: 1.4; }


  .ritual-banner {
    background: #6D5E53 url('https://images.unsplash.com/photo-1603006905003-be475563bc59?auto=format&fit=crop&q=80&w=2000') no-repeat center;
    background-size: cover;
    border-radius: 20px;
    height: 250px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-end;
    padding: 0 100px;
    margin-bottom: 100px;
    position: relative;
    color: #fff;
  }
  .ritual-banner::before { content: ''; position: absolute; inset: 0; background: rgba(0,0,0,0.2); border-radius: 20px; }
  .ritual-content { position: relative; z-index: 1; text-align: right; }
  .ritual-content h2 { font-family: 'Lora', serif; font-size: 36px; margin-bottom: 20px; font-weight: 400; }
  .ritual-btn { background: #fff; color: var(--color-text-dark); padding: 12px 30px; border-radius: 100px; text-decoration: none; font-size: 13px; font-weight: 600; }


  .lower-layout { display: grid; grid-template-columns: 1.5fr 1fr 1.5fr; gap: 60px; margin-bottom: 120px; }


  .accordion-item { border-bottom: 1px solid var(--color-border); }
  .accordion-title { padding: 18px 0; display: flex; justify-content: space-between; align-items: center; cursor: pointer; font-size: 14px; font-weight: 700; }
  .accordion-content { padding-bottom: 20px; font-size: 14px; color: var(--color-text-light); line-height: 1.6; display: none; }
  .accordion-item.active .accordion-content { display: block; }
  .accordion-item.active svg { transform: rotate(180deg); }


  .how-to-use h3 { font-family: 'Lora', serif; font-size: 24px; margin-bottom: 30px; font-weight: 400; text-align: center; }
  .steps { display: flex; flex-direction: column; gap: 30px; }
  .step-item { display: flex; flex-direction: column; align-items: center; text-align: center; }
  .step-icon { width: 50px; height: 50px; background: var(--color-beige); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin-bottom: 15px; color: var(--color-purple); }
  .step-num { font-size: 16px; font-weight: 700; margin-bottom: 5px; }
  .step-text { font-size: 12px; color: var(--color-text-light); line-height: 1.5; }


  .reviews-summary h3 { font-family: 'Lora', serif; font-size: 24px; margin-bottom: 20px; font-weight: 400; }
  .rating-flex { display: flex; align-items: baseline; gap: 15px; margin-bottom: 25px; }
  .rating-big { font-size: 48px; font-weight: 600; }
  .rating-sub { font-size: 13px; color: var(--color-text-light); }

  .rating-bars { display: flex; flex-direction: column; gap: 8px; margin-bottom: 40px; }
  .bar-item { display: flex; align-items: center; gap: 10px; font-size: 12px; }
  .bar-track { flex: 1; height: 6px; background: #EEE; border-radius: 10px; overflow: hidden; }
  .bar-fill { height: 100%; background: var(--color-purple); border-radius: 10px; }

  .review-snippet { background: #fff; border: 1px solid var(--color-border); padding: 25px; border-radius: 12px; position: relative; }
  .review-quote { font-size: 13px; color: var(--color-text-light); font-style: italic; margin-bottom: 15px; display: block; }
  .review-author { font-size: 12px; font-weight: 700; }
  .review-nav { display: flex; gap: 10px; margin-top: 20px; }
  .nav-dot { width: 6px; height: 6px; background: #DDD; border-radius: 50%; cursor: pointer; }
  .nav-dot.active { background: var(--color-purple); }


  .cross-sell-section { margin-bottom: 120px; }
  .cross-sell-section h2 { font-family: 'Lora', serif; font-size: 32px; margin-bottom: 40px; font-weight: 400; }
  .product-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 30px; }
  .product-item { border-radius: 12px; overflow: hidden; background: #fff; }
  .product-img { aspect-ratio: 1; overflow: hidden; position: relative; }
  .product-img img { width: 100%; height: 100%; object-fit: cover; }
  .product-footer { padding: 15px; display: flex; justify-content: space-between; align-items: center; }
  .p-name { font-size: 14px; font-weight: 600; }
  .p-price { font-size: 13px; color: var(--color-text-light); margin-top: 4px; }
  .btn-cart-small { width: 32px; height: 32px; border-radius: 8px; border: 1px solid var(--color-border); display: flex; align-items: center; justify-content: center; cursor: pointer; }


  .newsletter-box {
    background: var(--color-beige);
    border-radius: 20px;
    padding: 60px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 40px;
  }
  .news-text h2 { font-family: 'Lora', serif; font-size: 32px; margin-bottom: 10px; }
  .news-text p { font-size: 14px; color: var(--color-text-light); }
  .news-form { display: flex; gap: 10px; flex: 1; max-width: 500px; }
  .news-form input { flex: 1; padding: 15px 20px; border-radius: 8px; border: 1px solid var(--color-border); font-size: 14px; }
  .news-form button { background: var(--color-purple); color: #fff; padding: 15px 30px; border-radius: 8px; border: none; font-weight: 600; cursor: pointer; }
  .no-spam { font-size: 12px; color: #888; margin-top: 15px; display: block; }

  @media (max-width: 1024px) {
    .product-hero { grid-template-columns: 1fr; }
    .product-thumbnails { order: 2; flex-direction: row; justify-content: center; }
    .product-main-media { order: 1; }
    .product-info-wrap { order: 3; padding: 0; }
    .scent-notes-section, .lower-layout { grid-template-columns: 1fr; gap: 40px; }
    .benefits-grid { grid-template-columns: repeat(3, 1fr); }
    .product-grid { grid-template-columns: repeat(2, 1fr); }
    .newsletter-box { flex-direction: column; text-align: center; }
    .size-pills { grid-template-columns: repeat(3, 1fr); }
  }
</style>

<div class="product-container" id="ProductSection-{{ section.id }}" data-section-id="{{ section.id }}">
  <nav class="breadcrumbs">
    <a href="{{ routes.root_url }}">Home</a> <span>/</span> <a href="{{ routes.all_products_collection_url }}">Shop</a> <span>/</span> {{ product.title }}
  </nav>
  <div class="product-hero">
    <div class="product-thumbnails">
      {% for image in product.images %}
        <div class="thumb-item {% if forloop.first %}active{% endif %}" data-image="{{ image | image_url: width: 1000 }}">
          <img src="{{ image | image_url: width: 200 }}" alt="{{ image.alt }}">
        </div>
      {% endfor %}
    </div>

    <div class="product-main-media">
      <img id="MainProductImage" src="{{ product.featured_image | image_url: width: 1000 }}" alt="{{ product.title }}">
      <div class="zoom-icon">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      </div>
    </div>

    <div class="product-info-wrap">
      <span class="best-seller-tag">Best Seller</span>
      <h1 class="product-title">{{ product.title }}</h1>

      <div class="product-rating">
        <span class="stars">★★★★★</span>
        <span>4.8 (124 reviews)</span>
      </div>

      <p class="product-price" id="MainProductPrice">{{ product.selected_or_first_available_variant.price | money }}</p>
      <p class="tax-note">Inclusive of all taxes</p>

      <span class="catch-phrase">Sweet Serenity in Every Flicker 🫐 🕯️</span>
      <p class="short-desc">
        A delightful blend of juicy, fruity blueberry and soft, creamy vanilla that's both uplifting and calming.
      </p>

      <form method="post" action="{{ routes.cart_add_url }}" id="AddToCartForm">
        {% liquid
          assign first_variant = product.selected_or_first_available_variant
        %}
        <input type="hidden" name="id" value="{{ first_variant.id }}" id="SelectedVariantId">

        <span class="option-label">Choose Size</span>
        <div class="size-pills">
          {% for variant in product.variants %}
            {% liquid
              assign is_popular = false
              if variant.title contains 'Medium' or variant.title contains '8 oz'
                assign is_popular = true
              endif

              assign weight = variant.title | split: ' / ' | last
              if weight == variant.title
                assign weight = ""
              endif

              assign burn_time = "15 hrs"
              if variant.title contains 'Medium' or variant.title contains '8 oz'
                assign burn_time = "30 hrs"
              elsif variant.title contains 'Large' or variant.title contains '12 oz'
                assign burn_time = "50 hrs"
              endif
            %}
            <div class="size-pill {% if variant.id == first_variant.id %}active{% endif %}"
                 data-variant-id="{{ variant.id }}"
                 data-price="{{ variant.price | money }}"
                 data-image="{{ variant.image | default: product.featured_image | image_url: width: 1000 }}">
              {% if is_popular %}<span class="pill-popular">Popular</span>{% endif %}
              <span class="pill-name">{{ variant.title | split: ' / ' | first }}</span>
              <span class="pill-info">{{ weight | default: "Standard" }} • {{ burn_time }}</span>
              <span class="pill-price">{{ variant.price | money_without_trailing_zeros }}</span>
            </div>
          {% endfor %}
        </div>

        <div class="qty-selector">
          <span class="option-label" style="margin: 0;">Quantity</span>
          <div class="qty-controls">
            <button type="button" class="qty-btn minus">-</button>
            <input type="number" name="quantity" value="1" min="1" class="qty-input">
            <button type="button" class="qty-btn plus">+</button>
          </div>
        </div>

        <div class="button-group">
          <button type="submit" class="btn-add-to-cart">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
            Add to Cart
          </button>
          <button type="submit" name="checkout" class="btn-buy-now">Buy Now</button>
        </div>
      </form>

      <div class="trust-badges">
        <div class="trust-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20.42 4.58a5 5 0 0 1 0 7.07l-7.07 7.07a1 1 0 0 1-1.41 0L4.87 11.65a5 5 0 0 1 7.07-7.07l.36.36.36-.36a5 5 0 0 1 7.76 0Z"/></svg>
          Hand-poured with love
        </div>
        <div class="trust-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8h-2c0-2.67-.67-4.67-2-6-1.33 1.33-2 3.33-2 6h-2c0-2.67-.67-4.67-2-6-1.33 1.33-2 3.33-2 6Z"></path></svg>
          100% Natural Soy Wax
        </div>
        <div class="trust-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z"/></svg>
          Non-toxic Fragrance
        </div>
        <div class="trust-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2v20M2 12h20M12 2a10 10 0 0 1 10 10M12 22a10 10 0 0 1-10-10"/></svg>
          Clean Burn & Safe
        </div>
      </div>
    </div>
  </div>
  <div class="scent-notes-section">
    <div class="notes-intro">
      <h2>A Moment of Calm, Poured into Every Jar</h2>
      <p>Imagine walking into a sun-drenched kitchen where fresh blueberries simmer alongside warm vanilla. That's exactly the feeling our Blueberry Vanilla Fragrance Candle brings to your space.</p>
    </div>
    <div class="notes-grid">
      <div class="note-card">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
        <span class="note-type">Top Notes</span>
        <span class="note-name">Fresh Blueberry Burst</span>
      </div>
      <div class="note-card">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z"/></svg>
        <span class="note-type">Heart Notes</span>
        <span class="note-name">Creamy Vanilla Blend</span>
      </div>
      <div class="note-card">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
        <span class="note-type">Base Notes</span>
        <span class="note-name">Soft Warm Musk</span>
      </div>
    </div>
  </div>
  <div class="benefits-section">
    <h2>Why You'll Love It</h2>
    <div class="benefits-grid">
      <div class="benefit-card">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        <span class="benefit-title">20+ Hours</span>
        <span class="benefit-desc">Long-lasting burn time</span>
      </div>
      <div class="benefit-card">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8h-2c0-2.67-.67-4.67-2-6-1.33 1.33-2 3.33-2 6h-2c0-2.67-.67-4.67-2-6-1.33 1.33-2 3.33-2 6Z"></path></svg>
        <span class="benefit-title">Natural Soy Wax</span>
        <span class="benefit-desc">Eco-friendly & sustainable</span>
      </div>
      <div class="benefit-card">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20.42 4.58a5 5 0 0 1 0 7.07l-7.07 7.07a1 1 0 0 1-1.41 0L4.87 11.65a5 5 0 0 1 7.07-7.07l.36.36.36-.36a5 5 0 0 1 7.76 0Z"/></svg>
        <span class="benefit-title">Stress Relief</span>
        <span class="benefit-desc">Calming aroma for relaxation</span>
      </div>
      <div class="benefit-card">
