<style>
  .candles-hero {
    position: relative;
    width: 100%;
    height: 90vh;
    overflow: hidden;
    display: flex;
    align-items: center;
    background-color: #1a1a1a;
  }

  .candles-hero-slides {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
    display: flex;
    transition: transform 1.2s cubic-bezier(0.77, 0, 0.175, 1);
  }

  .hero-slide {
    min-width: 100%;
    height: 100%;
    position: relative;
    overflow: hidden;
  }

  .hero-slide img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transform: scale(1.05);
    transition: transform 10s linear;
  }

  .hero-slide.active img {
    transform: scale(1);
  }

  /* Overlay to ensure text readability */
  .hero-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(to right, rgba(0,0,0,0.4) 0%, transparent 60%);
    z-index: 3;
    pointer-events: none;
  }

  .candles-hero-content {
    position: relative;
    z-index: 4;
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 80px;
    width: 100%;
  }

  .candles-hero-inner {
    max-width: 600px;
    opacity: 0;
    transform: translateY(30px);
    color: #fff;
  }

  .candles-hero-label {
    font-size: 11px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.25em;
    margin-bottom: 30px;
    display: block;
    color: rgba(255, 255, 255, 0.8);
  }

  .candles-hero-title {
    font-family: 'Lora', serif;
    font-size: 72px;
    line-height: 1.1;
    font-weight: 400;
    margin-bottom: 40px;
  }

  .candles-hero-divider {
    width: 80px;
    height: 1px;
    background: #c5a880;
    margin-bottom: 40px;
  }

  .candles-hero-subtitle {
    font-size: 16px;
    line-height: 1.8;
    color: rgba(255, 255, 255, 0.9);
    max-width: 480px;
  }

  /* Navigation Dots */
  .hero-nav {
    position: absolute;
    bottom: 40px;
    left: 80px;
    z-index: 10;
    display: flex;
    gap: 15px;
  }

  .hero-dot {
    width: 40px;
    height: 2px;
    background: rgba(255, 255, 255, 0.3);
    cursor: pointer;
    transition: background 0.3s ease;
  }

  .hero-dot.active {
    background: #fff;
  }

  @media (max-width: 1024px) {
    .candles-hero {
      height: 70vh;
    }
    .candles-hero-content {
      padding: 0 40px;
    }
    .candles-hero-title {
      font-size: 54px;
    }
    .hero-nav {
      left: 40px;
    }
  }

  @media (max-width: 768px) {
    .candles-hero {
      height: 60vh;
      align-items: flex-end;
      padding-bottom: 60px;
    }
    .candles-hero-title {
      font-size: 38px;
    }
    .hero-overlay {
      background: linear-gradient(to top, rgba(0,0,0,0.6) 0%, transparent 60%);
    }
  }
</style>

<section class="candles-hero">
  <div class="candles-hero-slides" id="heroSlides">
    <div class="hero-slide active">
      <img src="https://placehold.co/1920x1080/1a1a1a/c5a880?text=Candle+Showcase+1" alt="Our Candles Slide 1">
    </div>
    <div class="hero-slide">
      <img src="https://placehold.co/1920x1080/1a1a1a/c5a880?text=Candle+Showcase+2" alt="Our Candles Slide 2">
    </div>
  </div>

  <div class="hero-overlay"></div>
  
  <div class="candles-hero-content">
    <div class="candles-hero-inner" id="candlesHeroInner">
      <span class="candles-hero-label">Our Candles</span>
      <h1 class="candles-hero-title">Scents that stay with you.</h1>
      <div class="candles-hero-divider"></div>
      <p class="candles-hero-subtitle">
        Handpoured with care using clean ingredients and timeless fragrances to bring warmth, comfort, and calm to your space.
      </p>
    </div>
  </div>

  <div class="hero-nav">
    <div class="hero-dot active" data-index="0"></div>
    <div class="hero-dot" data-index="1"></div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    // Initial entrance for text
    gsap.to('#candlesHeroInner', {
      opacity: 1,
      y: 0,
      duration: 1.5,
      ease: 'power3.out',
      delay: 0.5
    });

    const slidesContainer = document.getElementById('heroSlides');
    const dots = document.querySelectorAll('.hero-dot');
    let currentSlide = 0;
    const totalSlides = 2;

    function goToSlide(index) {
      currentSlide = index;
      slidesContainer.style.transform = `translateX(-${index * 100}%)`;
      
      // Update dots
      dots.forEach((dot, i) => {
        dot.classList.toggle('active', i === index);
      });
    }

    function autoSlide() {
      let next = (currentSlide + 1) % totalSlides;
      goToSlide(next);
    }

    // Dots click
    dots.forEach(dot => {
      dot.addEventListener('click', () => {
        clearInterval(slideInterval);
        goToSlide(parseInt(dot.dataset.index));
        slideInterval = setInterval(autoSlide, 6000);
      });
    });

    let slideInterval = setInterval(autoSlide, 6000);
  });
</script>

{% schema %}
{
  "name": "Candles Hero",
  "settings": []
}
{% endschema %}
