<style>
  .collection-main {
    background-color: #fdfaf5;
    padding: 150px 40px 60px 40px;
    min-height: 100vh;
  }

  @media (max-width: 768px) {
    .collection-main {
      padding: 120px 15px 30px 15px;
    }
  }

  .collection-layout {
    display: flex;
    gap: 40px;
    max-width: 1600px;
    margin: 0 auto;
  }


  .collection-sidebar {
    width: 280px;
    flex-shrink: 0;
  }

  .sidebar-inner {
    background: #fff;
    border: 1px solid #efebe5;
    border-radius: 4px;
    overflow: hidden;
  }

  .filter-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 20px 25px;
    border-bottom: 1px solid #efebe5;
  }

  .filter-header h2 {
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.1em;
    margin: 0;
    color: #1a1a1a;
  }

  .clear-all {
    font-size: 11px;
    font-weight: 600;
    color: #999;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .filter-group {
    padding: 25px;
    border-bottom: 1px solid #efebe5;
  }

  .filter-group-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 15px;
    cursor: pointer;
  }

  .filter-group-title {
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #1a1a1a;
  }

  .filter-toggle {
    font-size: 18px;
    font-weight: 300;
    color: #999;
  }

  .filter-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .filter-item {
    margin-bottom: 12px;
  }

  .filter-label {
    display: flex;
    align-items: center;
    font-size: 13px;
    color: #4a4a4a;
    cursor: pointer;
    transition: color 0.2s ease;
  }

  .filter-label:hover {
    color: #000;
  }

  .filter-checkbox {
    width: 16px;
    height: 16px;
    border: 1px solid #dcdcdc;
    margin-right: 12px;
    display: inline-block;
    position: relative;
    border-radius: 2px;
  }

  .filter-item input:checked + .filter-checkbox {
    background: #000;
    border-color: #000;
  }

  .filter-item input:checked + .filter-checkbox::after {
    content: '✓';
    color: #fff;
    font-size: 10px;
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
  }

  .filter-count {
    color: #999;
    margin-left: 5px;
  }

  .sidebar-footer-card {
    background: #f4f1eb;
    margin: 20px;
    padding: 25px;
    border-radius: 4px;
    text-align: left;
  }

  .footer-card-icon {
    margin-bottom: 15px;
    color: #4a4a4a;
  }

  .footer-card-title {
    font-size: 11px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 10px;
    display: block;
  }

  .footer-card-text {
    font-size: 11px;
    line-height: 1.6;
    color: #666;
  }


  .collection-content {
    flex: 1;
  }

  .collection-toolbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 30px;
  }

  .product-count-text {
    font-size: 14px;
    font-weight: 500;
    color: #1a1a1a;
  }

  .toolbar-right {
    display: flex;
    align-items: center;
    gap: 30px;
  }

  .sort-container {
    display: flex;
    align-items: center;
    gap: 15px;
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .sort-select-wrapper {
    position: relative;
  }

  .sort-select {
    border: none;
    background: none;
    font-size: 13px;
    color: #666;
    cursor: pointer;
    padding-right: 20px;
    outline: none;
  }

  .view-options {
    display: flex;
    gap: 10px;
    color: #999;
  }

  .view-btn {
    background: none;
    border: none;
    padding: 5px;
    cursor: pointer;
    color: #999;
    transition: color 0.2s ease;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .view-btn.active {
    color: #000;
  }


  .product-grid.list-view {
    grid-template-columns: 1fr !important;
    gap: 40px;
  }

  .product-grid.list-view .product-card {
    flex-direction: row;
    gap: 40px;
    align-items: center;
  }

  .product-grid.list-view .product-image-container {
    width: 300px;
    margin-bottom: 0;
    flex-shrink: 0;
  }

  .product-grid.list-view .product-details {
    flex: 1;
    text-align: left;
  }

  .product-grid.list-view .product-title {
    font-size: 24px;
    margin-bottom: 10px;
  }

  .product-grid.list-view .product-meta {
    justify-content: flex-start;
    gap: 20px;
    margin-bottom: 25px;
  }

  .product-grid.list-view .add-to-cart-btn {
    width: auto;
    padding: 15px 60px;
  }

  .product-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 30px;
  }

  .product-card {
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    background: #fff;
    border-radius: 8px;
    padding: 15px;
    border: 1px solid #efebe5;
    transition: box-shadow 0.3s ease;
  }

  .product-card:hover {
    box-shadow: 0 10px 30px rgba(0,0,0,0.05);
  }

  .product-image-container {
    position: relative;
    border-radius: 4px;
    overflow: hidden;
    aspect-ratio: 1;
    margin-bottom: 20px;
  }

  .product-image-container img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.165, 0.84, 0.44, 1);
  }

  .product-card:hover .product-image-container img {
    transform: scale(1.05);
  }

  .badge {
    position: absolute;
    top: 15px;
    left: 15px;
    background: #1a1a1a;
    color: #fff;
    padding: 6px 12px;
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    border-radius: 2px;
    z-index: 2;
  }

  .badge-best-seller {
    background: #e6ded3;
    color: #000;
  }

  .wishlist-btn {
    position: absolute;
    top: 15px;
    right: 15px;
    background: rgba(255,255,255,0.8);
    border: none;
    color: #1a1a1a;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 2;
    transition: all 0.3s ease;
  }

  .wishlist-btn:hover {
    background: #fff;
    transform: scale(1.1);
  }

  .product-details {
    padding: 0;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }

  .product-title {
    font-size: 18px;
    font-weight: 700;
    margin: 0 0 8px 0;
    color: #1a1a1a;
    line-height: 1.3;
    min-height: 46px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .product-scent {
    font-size: 13px;
    color: #888;
    margin-bottom: 20px;
    min-height: 18px;
  }


  .choose-size-label {
    font-size: 11px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #1a1a1a;
    margin-bottom: 12px;
    display: block;
  }

  .size-selection-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(80px, 1fr));
    gap: 10px;
    margin-bottom: 25px;
  }

  .size-option-card {
    border: 1px solid #eee;
    border-radius: 6px;
    padding: 12px 5px;
    text-align: center;
    cursor: pointer;
    transition: all 0.2s ease;
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .size-option-card:hover {
    border-color: #ccc;
  }

  .size-option-card.active {
    border-color: #6d5e53;
    background: #fdfaf5;
    box-shadow: 0 0 0 1px #6d5e53;
  }

  .size-name {
    font-size: 12px;
    font-weight: 700;
    margin-bottom: 4px;
    display: block;
  }

  .size-info {
    font-size: 10px;
    color: #888;
    display: block;
    line-height: 1.4;
  }

  .size-price {
    font-size: 11px;
    font-weight: 700;
    margin-top: 6px;
    display: block;
    color: #1a1a1a;
  }

  .popular-badge {
    position: absolute;
    top: -8px;
    left: 50%;
    transform: translateX(-50%);
    background: #6d5e53;
    color: #fff;
    font-size: 7px;
    font-weight: 800;
    padding: 2px 6px;
    border-radius: 100px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    white-space: nowrap;
  }

  .add-to-cart-form {
    margin-top: auto;
  }

  .add-to-cart-btn {
    width: 100%;
    background: #1a1a1a;
    color: #fff;
    border: none;
    padding: 16px;
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    cursor: pointer;
    border-radius: 4px;
    transition: all 0.3s ease;
  }

  .add-to-cart-btn:hover {
    background: #333;
    transform: translateY(-2px);
  }

  .free-shipping-note {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    font-size: 11px;
    color: #999;
    margin-top: 15px;
  }

  .free-shipping-note svg {
    color: #ccc;
  }

  @media (max-width: 1400px) {
    .product-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .product-grid {
      grid-template-columns: 1fr;
    }
    .size-selection-grid {
      gap: 6px;
    }
    .size-option-card {
      padding: 10px 2px;
    }
  }

  .apply-filters-btn {
    width: calc(100% - 50px);
    margin: 25px;
    background: #1a1a1a;
    color: #fff;
    border: none;
    padding: 15px;
    font-size: 11px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    cursor: pointer;
    border-radius: 2px;
    transition: all 0.3s ease;
  }

  .apply-filters-btn:hover {
    background: #333;
    letter-spacing: 0.2em;
  }
</style>

{% liquid
  assign current_collection = section.settings.collection | default: collection
  assign products_to_show = current_collection.products

  if section.settings.product_list != blank
    assign products_to_show = section.settings.product_list
  endif
%}

<section class="collection-main">
  <div class="collection-layout">
    {% if section.settings.show_sidebar %}
    <aside class="collection-sidebar">
      <div class="sidebar-inner">
        <div class="filter-header">
          <h2>FILTERS</h2>
          <a href="#" class="clear-all">Clear All</a>
        </div>
        <div class="filter-group">
          <div class="filter-group-header">
            <span class="filter-group-title">Category</span>
            <span class="filter-toggle">−</span>
          </div>
          <ul class="filter-list">
            <li class="filter-item"><label class="filter-label"><input type="checkbox" value="all" data-filter-type="category" class="filter-input" style="display:none;"><span class="filter-checkbox"></span> All</label></li>
            <li class="filter-item"><label class="filter-label"><input type="checkbox" value="diffuser" data-filter-type="category" class="filter-input" style="display:none;"><span class="filter-checkbox"></span> Diffuser</label></li>
            {% assign types = products_to_show | map: 'type' | uniq %}
            {% for type in types %}
              {% if type != blank %}
                <li class="filter-item">
                  <label class="filter-label">
                    <input type="checkbox" value="{{ type | handleize }}" data-filter-type="category" class="filter-input" style="display:none;">
                    <span class="filter-checkbox"></span>
                    {{ type }}
                  </label>
                </li>
              {% endif %}
            {% endfor %}
          </ul>
        </div>
        <div class="filter-group">
          <div class="filter-group-header">
            <span class="filter-group-title">Scent</span>
            <span class="filter-toggle">−</span>
          </div>
          <ul class="filter-list">
            {% assign all_tags = products_to_show | map: 'tags' | join: ',' | split: ',' | uniq %}
            {% assign exclude_tags = "new,best-seller,featured,sale" | split: "," %}
            {% for tag in all_tags %}
              {% assign tag_handle = tag | handleize %}
              {% unless exclude_tags contains tag_handle or tag_handle == blank %}
                <li class="filter-item">
                  <label class="filter-label">
                    <input type="checkbox" value="{{ tag_handle }}" data-filter-type="scent" class="filter-input" style="display:none;">
                    <span class="filter-checkbox"></span>
                    {{ tag | capitalize }}
                  </label>
                </li>
              {% endunless %}
            {% endfor %}
          </ul>
        </div>

        <button class="apply-filters-btn" id="apply-filters-btn">UPDATE FILTERS</button>

        <div class="sidebar-footer-card">
          <div class="footer-card-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a10 10 0 0 1 10 10c0 5.523-4.477 10-10 10S2 17.523 2 12 6.477 2 12 2Z"></path><path d="m9 12 2 2 4-4"></path></svg>
          </div>
          <span class="footer-card-title">Clean & Conscious</span>
          <p class="footer-card-text">All our candles are made with natural ingredients, clean fragrances, and eco-friendly materials.</p>
        </div>
      </div>
    </aside>
    {% endif %}
    <div class="collection-content">
      <div class="collection-toolbar">
        <div class="product-count-text">
          {{ products_to_show.size | default: 0 }} Products
        </div>
        <div class="toolbar-right">
          <div class="sort-container">
            <span>SORT BY:</span>
            <div class="sort-select-wrapper">
              <select class="sort-select">
                <option value="featured">Featured</option>
                <option value="price-asc">Price: Low to High</option>
                <option value="price-desc">Price: High to Low</option>
              </select>
            </div>
          </div>
          <div class="view-options">
            <button class="view-btn active" id="grid-view-btn" title="Grid View">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"></rect><rect x="14" y="3" width="7" height="7"></rect><rect x="14" y="14" width="7" height="7"></rect><rect x="3" y="14" width="7" height="7"></rect></svg>
            </button>
            <button class="view-btn" id="list-view-btn" title="List View">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="8" y1="6" x2="21" y2="6"></line><line x1="8" y1="12" x2="21" y2="12"></line><line x1="8" y1="18" x2="21" y2="18"></line><line x1="3" y1="6" x2="3.01" y2="6"></line><line x1="3" y1="12" x2="3.01" y2="12"></line><line x1="3" y1="18" x2="3.01" y2="18"></line></svg>
            </button>
          </div>
        </div>
      </div>

      <div class="product-grid" id="product-grid-main">
        {% for product in products_to_show %}
          {% liquid
            assign first_variant = product.selected_or_first_available_variant
            assign card_image = first_variant.image | default: product.featured_image
          %}
          {% capture product_tags %}{%- for tag in product.tags -%}{{ tag | handleize }}{% unless forloop.last %},{% endunless %}{%- endfor -%}{% endcapture %}
          <div class="product-card"
               data-category="{{ product.type | handleize }}"
               data-tags="{{ product_tags }}"
               data-price="{{ first_variant.price | divided_by: 100.0 }}"
               data-index="{{ forloop.index }}"
               id="product-{{ product.id }}">

            <div class="product-image-container">
              {% if product.tags contains 'new' %}
                <span class="badge">NEW</span>
              {% elsif product.tags contains 'best-seller' %}
                <span class="badge badge-best-seller">BEST SELLER</span>
              {% endif %}

              <button class="wishlist-btn">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>
              </button>

              <a href="{{ product.url }}">
                <img
                  class="main-card-img"
                  src="{{ card_image | image_url: width: 800 }}"
                  alt="{{ product.title }}"
                  width="{{ card_image.width }}"
                  height="{{ card_image.height }}"
                  loading="lazy"
                >
              </a>
            </div>

            <div class="product-details">
              <h3 class="product-title">{{ product.title }}</h3>
              <p class="product-scent">Sage • Pine • Eucalyptus</p>

              <span class="choose-size-label">Choose Size</span>

              <div class="size-selection-grid">
                {% for variant in product.variants %}
                  {% liquid
                    assign is_popular = false
                    if variant.title contains 'Medium' or variant.title contains '8 oz'
                      assign is_popular = true
                    endif

                    # Extract metadata for display
                    assign weight = variant.title | split: ' / ' | last
                    if weight == variant.title
                      assign weight = ""
                    endif

                    # Dummy burn time if not in metafields
                    assign burn_time = "15 hrs"
                    if variant.title contains 'Medium' or variant.title contains '8 oz'
                      assign burn_time = "30 hrs"
                    elsif variant.title contains 'Large' or variant.title contains '12 oz'
                      assign burn_time = "50 hrs"
                    endif
                  %}
                  <div class="size-option-card {% if variant.id == first_variant.id %}active{% endif %}"
                       data-variant-id="{{ variant.id }}"
                       data-price="{{ variant.price | money }}"
                       data-image="{{ variant.image | default: product.featured_image | image_url: width: 800 }}">
                    {% if is_popular %}<span class="popular-badge">Popular</span>{% endif %}
                    <span class="size-name">{{ variant.title | split: ' / ' | first }}</span>
                    <span class="size-info">{{ weight | default: "Standard" }}</span>
                    <span class="size-info">{{ burn_time }}</span>
                    <span class="size-price">{{ variant.price | money_without_trailing_zeros }}</span>
                  </div>
                {% endfor %}
              </div>

              <form method="post" action="{{ routes.cart_add_url }}" class="add-to-cart-form">
                <input type="hidden" name="id" value="{{ first_variant.id }}" class="variant-id-input">
                <button type="submit" class="add-to-cart-btn">ADD TO CART</button>
              </form>

              <div class="free-shipping-note">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"></rect><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon><circle cx="5.5" cy="18.5" r="2.5"></circle><circle cx="18.5" cy="18.5" r="2.5"></circle></svg>
                Free shipping on orders above Rs. 999
              </div>
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Main Collection Redesign",
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection Override"
    },
    {
      "type": "product_list",
      "id": "product_list",
      "label": "Manual Product Selection"
    },
    {
      "type": "checkbox",
      "id": "show_sidebar",
      "label": "Show Sidebar Filters",
      "default": true
    }
  ]
}
{% endschema %}

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const productCards = Array.from(document.querySelectorAll('.product-card'));
    const productTags = new Map(productCards.map(card => [
      card,
      (card.dataset.tags || '')
        .split(',')
        .map(tag => tag.trim())
        .filter(Boolean)
    ]));

    productCards.forEach(card => {
      const sizeOptions = card.querySelectorAll('.size-option-card');
      const mainImg = card.querySelector('.main-card-img');
      const variantIdInput = card.querySelector('.variant-id-input');

      sizeOptions.forEach(option => {
        option.addEventListener('click', function() {
          sizeOptions.forEach(opt => opt.classList.remove('active'));
          this.classList.add('active');
          const newImg = this.getAttribute('data-image');
          if (newImg && mainImg) {
            mainImg.src = newImg;
          }
          const newId = this.getAttribute('data-variant-id');
          if (newId && variantIdInput) {
            variantIdInput.value = newId;
          }
        });
      });
    });
    const gridBtn = document.getElementById('grid-view-btn');
    const listBtn = document.getElementById('list-view-btn');
    const grid = document.getElementById('product-grid-main');

    if (gridBtn && listBtn && grid) {
      gridBtn.addEventListener('click', () => {
        grid.classList.remove('list-view');
        gridBtn.classList.add('active');
        listBtn.classList.remove('active');
      });

      listBtn.addEventListener('click', () => {
        grid.classList.add('list-view');
        listBtn.classList.add('active');
        gridBtn.classList.remove('active');
      });
    }
    const applyFiltersBtn = document.getElementById('apply-filters-btn');
    const clearAllBtn = document.querySelector('.clear-all');
    const allCheckbox = document.querySelector('.filter-input[value="all"]');
    const filterInputs = Array.from(document.querySelectorAll('.filter-input'));
    const countDisplay = document.querySelector('.product-count-text');

    const getCheckedFilterValues = filterType => filterInputs
      .filter(input => input.dataset.filterType === filterType && input.checked && input.value !== 'all')
      .map(input => input.value);

    function applyFilters() {
      const selectedCategories = getCheckedFilterValues('category');
      const selectedScents = getCheckedFilterValues('scent');
      const isAllSelected = Boolean(allCheckbox && allCheckbox.checked);
      let visibleCount = 0;

      productCards.forEach(card => {
        const tags = productTags.get(card) || [];
        const categoryMatch = selectedCategories.length === 0
          || isAllSelected
          || selectedCategories.includes(card.dataset.category);
        const scentMatch = selectedScents.length === 0 || selectedScents.some(scent => tags.includes(scent));
        const isVisible = categoryMatch && scentMatch;

        card.style.display = isVisible ? 'flex' : 'none';
        if (isVisible) visibleCount += 1;
      });

      if (countDisplay) countDisplay.textContent = `${visibleCount} Products`;
    }

    if (applyFiltersBtn) {
      applyFiltersBtn.addEventListener('click', applyFilters);
    }

    if (allCheckbox) {
      allCheckbox.addEventListener('change', function() {
        if (this.checked) {
          filterInputs.forEach(input => {
            if (input !== this) input.checked = false;
          });
          applyFilters();
        }
      });
    }

    filterInputs.forEach(input => {
      if (input.value !== 'all') {
        input.addEventListener('change', function() {
          if (this.checked && allCheckbox) {
            allCheckbox.checked = false;
          }
        });
      }
    });

    if (clearAllBtn) {
      clearAllBtn.addEventListener('click', function(e) {
        e.preventDefault();
        filterInputs.forEach(input => input.checked = false);
        applyFilters();
      });
    }

    const sortSelect = document.querySelector('.sort-select');
    if (sortSelect && grid) {
      sortSelect.addEventListener('change', function() {
        const value = this.value;
        const cards = Array.from(grid.querySelectorAll('.product-card'));

        cards.sort((a, b) => {
          if (value === 'price-asc') {
            return parseFloat(a.getAttribute('data-price')) - parseFloat(b.getAttribute('data-price'));
          } else if (value === 'price-desc') {
            return parseFloat(b.getAttribute('data-price')) - parseFloat(a.getAttribute('data-price'));
          } else {
            return parseInt(a.getAttribute('data-index')) - parseInt(b.getAttribute('data-index'));
          }
        });

        cards.forEach(card => grid.appendChild(card));
      });
    }
  });
</script>
