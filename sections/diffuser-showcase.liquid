<style>
  #showcase-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    padding: 120px 0;
    overflow: hidden;
    color: #1a1a1a;
    position: relative;
  }

  #showcase-{{ section.id }}::before {
    content: '';
    position: absolute;
    top: 0;
    left: 5%;
    right: 5%;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(197, 168, 128, 0.3), transparent);
  }

  .diffuser-showcase-container-{{ section.id }} {
    max-width: 100%;
    margin: 0;
    display: flex;
    flex-direction: {% if section.settings.reverse_layout %}row-reverse{% else %}row{% endif %};
    gap: 100px;
    align-items: center;
  }

  .diffuser-showcase-image-{{ section.id }} {
    flex: 1.2;
    position: relative;
    height: 600px;
    border-radius: 0;
    overflow: hidden;
    clip-path: inset(0 0 100% 0);
    box-shadow: {% if section.settings.reverse_layout %}inset 10px 0 30px rgba(0,0,0,0.03){% else %}inset -10px 0 30px rgba(0,0,0,0.03){% endif %};
  }

  .diffuser-showcase-image-{{ section.id }} img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    object-position: center bottom;
    transform: scale(1.1);
    transform-origin: center bottom;
    position: absolute;
    top: 0;
    left: 0;
  }

  .diffuser-showcase-content-{{ section.id }} {
    flex: 1;
    padding: {% if section.settings.reverse_layout %}0 0 0 100px{% else %}0 100px 0 0{% endif %};
    position: relative;
    opacity: 0;
  }

  .editorial-number-{{ section.id }} {
    position: absolute;
    top: -60px;
    {% if section.settings.reverse_layout %}left: 40px;{% else %}left: -30px;{% endif %}
    font-family: 'Lora', serif;
    font-size: 200px;
    color: rgba(197, 168, 128, 0.05);
    z-index: 0;
    pointer-events: none;
    line-height: 1;
  }

  .diffuser-showcase-title-{{ section.id }} {
    font-family: 'Lora', serif;
    font-size: 56px;
    font-weight: 300;
    margin: 0 0 15px 0;
    color: #1a1a1a;
    position: relative;
    z-index: 1;
    letter-spacing: -0.02em;
  }

  .diffuser-showcase-subtitle-{{ section.id }} {
    font-family: 'Lora', serif;
    font-style: italic;
    font-size: 14px;
    color: #c5a880;
    margin-bottom: 30px;
    display: block;
    letter-spacing: 0.05em;
  }

  .diffuser-showcase-text-{{ section.id }} {
    font-size: 15px;
    line-height: 1.8;
    color: #555;
    margin-bottom: 50px;
    max-width: 480px;
    position: relative;
    z-index: 1;
  }

  .content-divider-{{ section.id }} {
    width: 40px;
    height: 1px;
    background-color: #c5a880;
    margin-bottom: 40px;
  }

  .vessel-label-{{ section.id }} {
    font-size: 9px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    margin-bottom: 25px;
    display: block;
    color: #888;
  }

  .vessel-options-{{ section.id }} {
    display: flex;
    gap: 15px;
    margin-bottom: 60px;
    max-width: 480px;
  }

  .vessel-box-{{ section.id }} {
    flex: 1;
    padding: 18px 10px;
    border: 1px solid #e8e2d5;
    background: transparent;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 8px;
    font-size: 11px;
    font-weight: 600;
    color: #1a1a1a;
    transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
    cursor: pointer;
    position: relative;
    overflow: hidden;
  }

  .vessel-box-{{ section.id }}::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: #f4eee6;
    transform: translateY(100%);
    transition: transform 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
    z-index: -1;
  }

  .vessel-box-{{ section.id }}:hover::before {
    transform: translateY(0);
  }

  .vessel-box-{{ section.id }}:hover {
    border-color: #d1bfae;
  }

  .vessel-icon-{{ section.id }} {
    width: 18px;
    height: 18px;
    color: #1a1a1a;
  }

  .pairings-label-{{ section.id }} {
    font-size: 9px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    margin-bottom: 30px;
    display: block;
    color: #888;
  }

  .pairings-grid-{{ section.id }} {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 25px;
    margin-bottom: 60px;
    max-width: 480px;
  }

  .pairing-item-{{ section.id }} {
    display: flex;
    flex-direction: column;
    gap: 12px;
    cursor: pointer;
    text-decoration: none;
  }

  .pairing-image-{{ section.id }} {
    aspect-ratio: 1;
    overflow: hidden;
    background: #f4eee6;
  }

  .pairing-image-{{ section.id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.8s cubic-bezier(0.165, 0.84, 0.44, 1);
  }

  .pairing-item-{{ section.id }}:hover .pairing-image-{{ section.id }} img {
    transform: scale(1.1);
  }

  .pairing-title-{{ section.id }} {
    font-size: 10px;
    font-weight: 600;
    color: #555;
    text-align: center;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .shop-btn-{{ section.id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    color: #1a1a1a;
    padding: 20px 40px;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    text-decoration: none;
    border: 1px solid #1a1a1a;
    transition: all 0.5s cubic-bezier(0.165, 0.84, 0.44, 1);
    width: 100%;
    max-width: 480px;
    position: relative;
    overflow: hidden;
    z-index: 1;
  }

  .shop-btn-{{ section.id }}::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: #1a1a1a;
    transform: scaleX(0);
    transform-origin: right;
    transition: transform 0.5s cubic-bezier(0.165, 0.84, 0.44, 1);
    z-index: -1;
  }

  .shop-btn-{{ section.id }}:hover {
    color: #fff;
  }

  .shop-btn-{{ section.id }}:hover::before {
    transform: scaleX(1);
    transform-origin: left;
  }

  @media (max-width: 1024px) {
    #showcase-{{ section.id }} {
      padding: 60px 0;
    }
    .diffuser-showcase-container-{{ section.id }} {
      flex-direction: column{% if section.settings.reverse_layout %}-reverse{% endif %};
      gap: 40px;
    }
    .diffuser-showcase-content-{{ section.id }} {
      padding: 0 40px;
    }
    .diffuser-showcase-image-{{ section.id }} {
      height: 500px;
    }
  }
</style>

<section id="showcase-{{ section.id }}">
  <div class="diffuser-showcase-container-{{ section.id }}">
    <div class="diffuser-showcase-image-{{ section.id }}" id="image-{{ section.id }}">
      <img src="{{ section.settings.image_filename | asset_url }}" alt="{{ section.settings.title }}">
    </div>

    <div class="diffuser-showcase-content-{{ section.id }}" id="content-{{ section.id }}">
      <div class="editorial-number-{{ section.id }}">{{ section.settings.number }}</div>
      <h2 class="diffuser-showcase-title-{{ section.id }}">{{ section.settings.title }}</h2>
      <span class="diffuser-showcase-subtitle-{{ section.id }}">{{ section.settings.subtitle }}</span>
      <p class="diffuser-showcase-text-{{ section.id }}">
        {{ section.settings.text }}
      </p>

      <div class="content-divider-{{ section.id }}"></div>

      <span class="vessel-label-{{ section.id }}">Aromatic Intensity</span>
      <div class="vessel-options-{{ section.id }}">
        <div class="vessel-box-{{ section.id }}">
          <div class="vessel-icon-{{ section.id }}">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v20"></path><path d="M2 12h20"></path></svg>
          </div>
          SUBTLE
        </div>
        <div class="vessel-box-{{ section.id }}">
          <div class="vessel-icon-{{ section.id }}">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v20"></path><path d="M2 12h20"></path></svg>
          </div>
          BALANCED
        </div>
        <div class="vessel-box-{{ section.id }}">
          <div class="vessel-icon-{{ section.id }}">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v20"></path><path d="M2 12h20"></path></svg>
          </div>
          INTENSE
        </div>
      </div>

      <span class="pairings-label-{{ section.id }}">Curated Pairings</span>
      <div class="pairings-grid-{{ section.id }}">
        <div class="pairing-item-{{ section.id }}">
          <div class="pairing-image-{{ section.id }}"><img src="{{ 'diffuser-1.jpg' | asset_url }}" alt="Pairing 1"></div>
          <span class="pairing-title-{{ section.id }}">Sandalwood</span>
        </div>
        <div class="pairing-item-{{ section.id }}">
          <div class="pairing-image-{{ section.id }}"><img src="{{ 'diffuser-2.jpg' | asset_url }}" alt="Pairing 2"></div>
          <span class="pairing-title-{{ section.id }}">Lavender</span>
        </div>
        <div class="pairing-item-{{ section.id }}">
          <div class="pairing-image-{{ section.id }}"><img src="{{ 'diffuser-3.jpg' | asset_url }}" alt="Pairing 3"></div>
          <span class="pairing-title-{{ section.id }}">Citrus</span>
        </div>
        <div class="pairing-item-{{ section.id }}">
          <div class="pairing-image-{{ section.id }}"><img src="{{ 'diffuser-4.jpg' | asset_url }}" alt="Pairing 4"></div>
          <span class="pairing-title-{{ section.id }}">Ocean</span>
        </div>
      </div>

      <a href="{{ section.settings.link }}" class="shop-btn-{{ section.id }}">Acquire This Diffuser</a>
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    if (typeof gsap !== 'undefined') {
      const tl = gsap.timeline({
        scrollTrigger: {
          trigger: '#showcase-{{ section.id }}',
          start: 'top 70%',
          toggleActions: 'play none none none'
        }
      });

      tl.to('#image-{{ section.id }}', {
        clipPath: 'inset(0 0 0% 0)',
        duration: 1.8,
        ease: 'power3.inOut'
      }, 0);

      tl.to('#content-{{ section.id }}', {
        opacity: 1,
        duration: 1.2,
        ease: 'power2.out'
      }, 0.2);

      tl.from('#content-{{ section.id }} > *', {
        y: 30,
        opacity: 0,
        duration: 1,
        stagger: 0.1,
        ease: 'power3.out'
      }, 0.5);

      gsap.to('#image-{{ section.id }} img', {
        scrollTrigger: {
          trigger: '#showcase-{{ section.id }}',
          start: 'top bottom',
          end: 'bottom top',
          scrub: true
        },
        y: '15%',
        ease: 'none'
      });
    }
  });
</script>

{% schema %}
{
  "name": "Diffuser Showcase",
  "settings": [
    {
      "type": "text",
      "id": "number",
      "label": "Editorial Number",
      "default": "01"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Diffuser Fragrance"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "FRAGRANCE NO. 01 — AROMATIC BLISS"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Description",
      "default": "A sophisticated blend of essential oils designed to transform your environment into a sanctuary of calm and elegance."
    },
    {
      "type": "text",
      "id": "image_filename",
      "label": "Asset Filename (e.g. diffuser-1.jpg)"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Product Link"
    },
    {
      "type": "checkbox",
      "id": "reverse_layout",
      "label": "Reverse Layout",
      "default": false
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#fcfaf7"
    }
  ]
}
{% endschema %}
